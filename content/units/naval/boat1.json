type: naval

//speed, health, armor, drag, accel, hitsize, rotate speed and trailLength can be changed
speed: 1
health: 500
armor: 2
aimDst: 10
range: 90
drag: 0.1
accel: 1
hitSize: 10
rotateSpeed: 2.4
trailLength: 15
outlineColor: 13151AFF
moveSoundVolume: 0.34
moveSound: shipMove

//configure this however you want. this is juts a basic idea that you might not even like
weapons: [
  {
    mirror: false
    alternate: false
    rotate: true
    #name: 
    rotateSpeed: 2
    x: 0
    y: -2
    reload: 60
    recoil: 1.25
    shootSound: shootCyclone
    shootSoundVolume: 0.09
    shoot: {
      shots: 3
      shotDelay: 5
    } 
    bullet: {
      keepVelocity: false
      type: BasicBulletType
      #sprite:
      width: 8
      height: 12
      splashDamageRadius: 12
      splashDamage: 10
      lifetime: 40
      damage: 15
      speed: 0.5
      accel: 0.1
      smokeEffect: shootSmallSmoke
      trailColor: FFA600
      trailWidth: 1
      trailLength: 6
      backColor: E2A000
      hitColor: E2A000
      despawnEffect: {
        type: WaveEffect
        rotWithParent: true
        followParent: true
        lifetime: 8
        sizeFrom: 0
        sizeTo: 15
        colorFrom: ffffff
        colorTo: FFA600
      }
    }
  }
]


immunities: [
  wet
]
