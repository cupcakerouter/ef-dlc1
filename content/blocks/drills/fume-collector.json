type: ThermalGenerator
name: Fume collector
description: Collects carbon dioxide emitted from vents. Additionally outputs some power.
size: 3
attribute: steam
displayEfficiencyScale: 0.11111111111
displayEfficiency: false
minEfficiency: 8
powerProduction: 0.22222222222222222
generateEffect: turbinegenerate
effectChance: 0.03
squareSprite: false
category: production
hasLiquids: true
hasPower: true


outputLiquid: efdlc-carbon-dioxide/0.016666666666666666666


requirements: [
    efdlc-scrap/35
]


ambientSound: loopHum
ambientSoundVolume: 0.12

drawer: {
  type: DrawMulti
  drawers: [
    {
      type: DrawRegion
      suffix: -bottom
    }
    {
      type: DrawLiquidRegion
      suffix: -liquid
      drawLiquid: efdlc-carbon-dioxide
      alpha: 1
      padding: 3
    } 
    {
      type: DrawRegion
      suffix: -rotator
      spinSprite: true
      rotateSpeed: -5
    }
    {
      type: DrawDefault
    }
  ]
}





